# ─── UNIDEL HRMS Server Environment ───────────────────────────────────────────
# Copy this file to .env and fill in your values before running the server.

# MongoDB connection string
# Local:   mongodb://localhost:27017/unidel_hrms
# Atlas:   mongodb+srv://<user>:<password>@cluster.mongodb.net/unidel_hrms
MONGO_URI=mongodb://localhost:27017/unidel_hrms

# JWT secret — use a long random string in production
JWT_SECRET=unidel_hrms_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d

# Server port
PORT=5000

# Client origin for CORS
CLIENT_URL=http://localhost:3000

# Node environment: development | production
NODE_ENV=development

# AI Vetting thresholds
AI_PROMOTION_PASS_SCORE=75
AI_ANOMALY_FLAG_THRESHOLD=0.85

# Logging level: error | warn | info | debug
LOG_LEVEL=info

# Email / SMTP (leave blank to use dev log-only mode)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=UNIDEL StaffOS <noreply@unidel.edu.ng>
